# ── Sentiment engine ─────────────────────────────────────────────────────────
# Option A (online, best): Groq API — free tier at https://console.groq.com
# Model: llama-3.3-70b-versatile (fastest 70B, free generous limits)
GROQ_API_KEY=

# Option B (offline, automatic fallback):
# FinBERT + Hartmann DistilRoBERTa ensemble
# Downloads ~760MB to ~/.cache/huggingface on first run. No key needed.

# ── Database ─────────────────────────────────────────────────────────────────
# Leave blank for local SQLite dev. Set for production (Neon free Postgres):
# postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=

# ── App ───────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production
